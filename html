<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<title>Juego de identificación</title>
<p id="mensaje" style="color: red; font-weight: bold; height: 20px;"></p>

<style>
  body {
    font-family: Arial;
    text-align: center;
    background-color: #f0f0f0;
  }

  h2 {
    margin: 10px;
  }

  .game-area {
    position: relative;
    width: 800px;
    margin: auto;
  }

  .game-area img {
    width: 100%;
  }

  .dropzone {
    position: absolute;
    width: 90px;
    height: 35px;
    border: 2px solid rgb(0, 0, 0);
    background: rgba(163, 163, 163, 0.3);
    border-radius: 6px;
    transition: all 1.0s ease;
  }

  /* POSICIONES */
  #zona1 { top: 30px; left: 50px; }
  #zona2 { top: 39px; left: 190px; }
  #zona3 { top: 39px; left: 420px; }
  #zona4 { top: 70px; left: 551px; }
  #zona5 { top: 230px; left: 540px; }
  #zona6 { top: 490px; left: 530px; }
  #zona7 { top: 340px; left: 320px; }
  #zona8 { top: 337px; left: 214px; }
  #zona9 { top: 298px; left: 170px; }
  #zona10 { top: 288px; left: 45px; }

  .correct {
    width: 90px;
    height: 35px;
    background: rgba(30, 255, 0, 0.699);
    border: 2px solid rgb(0, 0, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    text-align: center;
  }

    .incorrect {
    width: 90px;
    height: 35px;
    background: rgba(255, 0, 0, 0.699);
    border: 2px solid rgb(0, 0, 0);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 16px;
    text-align: center;
  }

  .items {
    margin-top: 20px;
  }

  .draggable {
    display: inline-block;
    padding: 10px;
    margin: 10px;
    background: rgba(151, 151, 151, 0.699);
    border-radius: 8px;
    cursor: pointer;
    transition: all 1.0s ease;
  }
</style>

</head>
<body>

<h2>Seleccioná una opción y luego hacé clic en su lugar correcto</h2>

<div class="game-area">
  <img src="./arma_plantilla.png">

  <div class="dropzone" id="zona1" data-match="p1"></div>
  <div class="dropzone" id="zona2" data-match="p2"></div>
  <div class="dropzone" id="zona3" data-match="p3"></div>
  <div class="dropzone" id="zona4" data-match="p4"></div>
  <div class="dropzone" id="zona5" data-match="p5"></div>
  <div class="dropzone" id="zona6" data-match="p6"></div>
  <div class="dropzone" id="zona7" data-match="p7"></div>
  <div class="dropzone" id="zona8" data-match="p8"></div>
  <div class="dropzone" id="zona9" data-match="p9"></div>
  <div class="dropzone" id="zona10" data-match="p10"></div>
</div>

<div class="items">
  <div class="draggable" id="p1">Guión</div>
  <div class="draggable" id="p2">Corredera</div>
  <div class="draggable" id="p3">Alza</div>
  <div class="draggable" id="p4">Martillo</div>
  <div class="draggable" id="p5">Seguro y Decocker</div>
  <div class="draggable" id="p6">Empuñadura</div>
  <div class="draggable" id="p7">Retén del cargador</div>
  <div class="draggable" id="p8">Retén de corredera</div>
  <div class="draggable" id="p9">Palanca de desarme</div>
  <div class="draggable" id="p10">Riel Picatinny</div>
</div>

<script>
const draggables = document.querySelectorAll('.draggable');
const dropzones = document.querySelectorAll('.dropzone');
const containerItems = document.querySelector('.items');

let seleccionActual = null;

// GUARDAMOS estado inicial
const estadoInicial = containerItems.innerHTML;

// seleccionar opción
draggables.forEach(item => {
  item.addEventListener('click', () => {
    document.querySelectorAll('.draggable').forEach(el => el.style.border = "none");
    seleccionActual = item;
    item.style.border = "2px solid black";
  });
});

// función reiniciar sin recargar
function reiniciarJuego() {
  // limpiar zonas
  dropzones.forEach(zone => {
    zone.innerHTML = "";
    zone.classList.remove('correct', 'incorrect');
  });

  // restaurar opciones
  containerItems.innerHTML = estadoInicial;

  // volver a asignar eventos (IMPORTANTE)
  const nuevosDraggables = document.querySelectorAll('.draggable');

  nuevosDraggables.forEach(item => {
    item.addEventListener('click', () => {
      document.querySelectorAll('.draggable').forEach(el => el.style.border = "none");
      seleccionActual = item;
      item.style.border = "2px solid black";
    });
  });

  seleccionActual = null;
}

// colocar en zona
dropzones.forEach(zone => {
  zone.addEventListener('click', () => {
    if (!seleccionActual) return;

    if (zone.dataset.match === seleccionActual.id) {
      zone.classList.add('correct');
    } else {
      zone.classList.add('incorrect');
    }

    zone.appendChild(seleccionActual);

    seleccionActual.style.background = "none";
    seleccionActual.style.margin = "0";
    seleccionActual.style.padding = "0";
    seleccionActual.style.cursor = "default";
    seleccionActual.style.pointerEvents = "none";
    seleccionActual.style.border = "none";

    seleccionActual = null;

    // si fue incorrecto → reiniciar
    if (zone.classList.contains('incorrect')) {
      setTimeout(() => {
        reiniciarJuego();
      }, 1500);
    }
  });
});
</script>

</body>
</html>
